<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="keywords" content="random chat, global chat, chat, chatspace, chat room, online chat, instant messaging" />
    <meta name="description" content="Chat Space — join global or private rooms for instant, anonymous conversations. Start chatting now." />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9495181960569580"
     crossorigin="anonymous"></script>
    <title>Chat - <%= room %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body class="chat-page bg-slate-50 text-slate-900" data-username="<%= username %>" data-room="<%= room %>">
    <nav class="sticky top-0 z-20 border-b border-slate-200 bg-white px-4 py-4 shadow-sm">
      <div class="mx-auto flex max-w-5xl items-center justify-between">
        <a class="text-lg font-semibold text-sky-600" href="/">Chat Space</a>
        <span class="text-sm text-slate-600">Room: <%= room %></span>
      </div>
    </nav>

    <div class="chat-window mx-auto flex h-[calc(var(--vh,1vh)*100-4rem)] max-w-5xl flex-col px-4 pb-4 pt-4 sm:px-6">
      <header class="chat-header mb-3 flex flex-col gap-3 rounded-3xl bg-white p-4 shadow-sm sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-slate-400">Connected as</p>
          <p class="text-lg font-semibold text-slate-900"><%= username %></p>
        </div>
        <div class="rounded-2xl bg-slate-100 px-4 py-2 text-sm text-slate-700">Room: <%= room %></div>
      </header>

      <main class="chat-main flex-1 overflow-y-auto rounded-3xl bg-white p-4 shadow-sm">
        <div id="messages" class="messages space-y-3"></div>
      </main>

      <form id="message-form" class="message-form sticky bottom-0 left-0 right-0 mt-4 flex gap-3 rounded-3xl bg-white px-4 py-3 shadow-lg shadow-slate-200/50 sm:mt-5">
        <input
          id="message-input"
          autocomplete="off"
          placeholder="Type a message..."
          required
          class="flex-1 rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-base text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"
        />
        <button
          type="submit"
          class="rounded-3xl bg-sky-600 px-5 py-3 text-base font-semibold text-white transition hover:bg-sky-700"
        >
          Send
        </button>
      </form>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/client.js"></script>
  </body>
</html>
