<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Chat - <%= room %></title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body data-username="<%= username %>" data-room="<%= room %>">
    <nav class="site-nav">
      <a class="logo" href="/">Chat Room</a>
      <span class="room-name">Room: <%= room %></span>
    </nav>
    <header class="chat-header">
      <div class="room-title">Room: <%= room %></div>
      <div class="user">You: <strong><%= username %></strong></div>
    </header>

    <main class="chat-main">
      <div id="messages" class="messages"></div>
    </main>

    <form id="message-form" class="message-form">
      <input id="message-input" autocomplete="off" placeholder="Type a message..." required />
      <button type="submit">Send</button>
    </form>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/client.js"></script>
  </body>
</html>
